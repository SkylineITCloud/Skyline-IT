# ─── SKYLINE IT — Environment Configuration ───
# Copy this file to .env and fill in your values.

# Server port (default: 3000)
PORT=3000

# Node environment (development / production)
NODE_ENV=development

# CORS origin allowed to access the API
# Set to your production domain when deploying
CORS_ORIGIN=https://www.skylineit.site

# Hidden admin API key — generate a strong random value
# Used to access /api/admin/* endpoints via X-Api-Key header
API_KEY=sk_your_secret_key_here

# License metadata (displayed by /api/health)
LICENSE_HOLDER=Skyline IT (S'nqobile Langa Hlatshwayo)
LICENSE_TYPE=MIT
